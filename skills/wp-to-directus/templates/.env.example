# Migration mode: "test" (use bundled Docker stack) or "external" (bring your own)
MIGRATION_MODE=test

# === WordPress source ===
WP_DB_HOST=localhost
WP_DB_PORT=3307
WP_DB_USER=wp_user
WP_DB_PASSWORD=change_me_wp
WP_DB_NAME=wordpress
WP_SITE_URL=http://localhost:8080
WP_INTERNAL_URL=http://wordpress:80

# === Directus target ===
DIRECTUS_URL=http://localhost:8055
DIRECTUS_ADMIN_TOKEN=change_me_static_token

# === Directus Postgres (read-only user for verify; optional in external mode) ===
DIRECTUS_DB_HOST=localhost
DIRECTUS_DB_PORT=5433
DIRECTUS_DB_USER=directus_readonly
DIRECTUS_DB_PASSWORD=change_me_readonly
DIRECTUS_DB_NAME=directus

# === Test stack only (ignored when MIGRATION_MODE=external) ===
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=wordpress
MYSQL_USER=wp_user
MYSQL_PASSWORD=change_me_wp
WORDPRESS_DB_HOST=wordpress_db:3306
WORDPRESS_DB_USER=wp_user
WORDPRESS_DB_PASSWORD=change_me_wp
WORDPRESS_DB_NAME=wordpress
POSTGRES_DB=directus
POSTGRES_USER=directus_user
POSTGRES_PASSWORD=change_me_pg
DIRECTUS_SECRET=change_me_secret_key
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=change_me_admin
