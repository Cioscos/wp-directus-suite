{
  "mcpServers": {
    "wordpress-mysql": {
      "command": "npx",
      "args": ["-y", "@bytebase/dbhub@latest", "--transport", "stdio",
               "--dsn", "mysql://USER:PWD@HOST:PORT/DB"]
    },
    "directus-postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres",
               "postgresql://USER:PWD@HOST:PORT/DB"]
    }
  }
}
