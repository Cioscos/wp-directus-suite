/// <reference types="vite/client" />
import { createDirectus, rest, staticToken } from "@directus/sdk";
import type { Schema } from "~/types/schema";

const DIRECTUS_URL = import.meta.env.VITE_DIRECTUS_URL ?? "{{ directus_url }}";
const DIRECTUS_TOKEN = import.meta.env.VITE_DIRECTUS_TOKEN as string | undefined;

const base = createDirectus<Schema>(DIRECTUS_URL).with(rest());
export const directus = DIRECTUS_TOKEN ? base.with(staticToken(DIRECTUS_TOKEN)) : base;
