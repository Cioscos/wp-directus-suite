import ReactDOM from "react-dom/client";
import { QueryClientProvider } from "@tanstack/react-query";
import type { PageContextClient } from "vike/types";
import { queryClient } from "~/lib/query-client";
import { Layout } from "./Layout";
{% if has_i18n %}import "~/lib/i18n";{% endif %}
import "~/styles/tailwind.css";

let root: ReactDOM.Root | null = null;

export async function onRenderClient(pageContext: PageContextClient) {
  const { Page, pageProps } = pageContext as typeof pageContext & { Page: React.FC<Record<string, unknown>>; pageProps: Record<string, unknown> };
  const container = document.getElementById("page-view");
  if (!container) throw new Error("#page-view not found");
  const tree = (
    <QueryClientProvider client={queryClient}>
      <Layout>
        <Page {...pageProps} />
      </Layout>
    </QueryClientProvider>
  );
  if (!root) {
    root = ReactDOM.createRoot(container);
  }
  root.render(tree);
}
